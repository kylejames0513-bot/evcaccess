# Copy to supabase-vercel.env (gitignored via .env*) and fill from
# Supabase Dashboard → Project Settings → API for ONE project.
# Then: npm run vercel:env:push-supabase -- supabase-vercel.env

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (Dashboard → API → service_role — never expose as NEXT_PUBLIC_*)
SUPABASE_SERVICE_ROLE_KEY=

# Shared Training Hub password (≥8 chars); used with npm run db:ensure-hr-user
GENERAL_HR_PASSWORD=

# Optional: duplicate server-style names (same values as above if you use them)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
