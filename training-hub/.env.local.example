# ============================================================
# EVC Training Hub -- Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
#
# SETUP:
#   1. Go to your Supabase project dashboard
#   2. Go to Settings > API to find your URL and keys
#   3. Create user accounts via Supabase Auth dashboard
# ============================================================

# Supabase project URL (from Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (from Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (from Settings > API)
# This is a SECRET key -- never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Legacy shared password for HR access (optional, for backward compat)
HR_PASSWORD=your-shared-password-here

# ------------------------------------------------------------
# Hub Sync token (for external VBA macros)
# ------------------------------------------------------------
# Long random string that the FY Separation Summary `HubSync.bas`
# macro and the Monthly New Hire Tracker `PushNewHires.bas` /
# `SyncFromSupabase` macros present in the `x-hub-sync-token` header
# when calling the /api/sync/* endpoints. Those endpoints bypass
# Supabase RLS (they run with the service role), so this token is
# the only thing gating write access from the workbooks.
#
# To rotate:
#   1. Generate a new token: `openssl rand -base64 48`
#   2. Update this env var on Vercel
#   3. Update the HUB_SYNC_TOKEN constant at the top of each .bas
#      file and re-import the module into Excel
HUB_SYNC_TOKEN=replace-with-a-long-random-string

# Environment
NODE_ENV=development
