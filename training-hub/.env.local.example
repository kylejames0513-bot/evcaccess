# ============================================================
# EVC Training Hub — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
#
# SETUP:
#   1. Go to Google Cloud Console → APIs & Services → Credentials
#   2. Create a Service Account (or use an existing one)
#   3. Download the JSON key file
#   4. Copy the "client_email" and "private_key" from the JSON
#   5. Share your EVC Attendance Tracker spreadsheet with the
#      service account email (give it Editor access)
#   6. Copy the spreadsheet ID from the URL:
#      https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
# ============================================================

# From the service account JSON key file → "client_email"
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# From the service account JSON key file → "private_key"
# Keep the \n characters — they'll be converted to real newlines
GOOGLE_SERVICE_ACCOUNT_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# The spreadsheet ID from your Google Sheet URL
# https://docs.google.com/spreadsheets/d/THIS_PART_IS_THE_ID/edit
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-here
