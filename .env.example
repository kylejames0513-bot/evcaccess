# --- Supabase + Vercel (Training Hub) ---
# 1) Vercel: link this repo to your project (creates .vercel/project.json; not committed):
#       npm run vercel:link
# 2) Supabase: either
#    A) Vercel Marketplace — Project → Storage → Supabase (or): npx vercel integration add supabase
#       then sync env to your machine: npm run vercel:env:pull
#    B) Existing project — copy Project URL + anon + service_role from Supabase Dashboard →
#       Settings → API into Vercel Environment Variables, then npm run vercel:env:pull
# 3) Link Supabase CLI to the same project (writes .supabase locally; not committed):
#       npm run supabase:link
# 4) Apply migrations to the linked remote DB (includes general HR gate user if missing):
#       npm run db:push
# 5) Regenerate TS types after schema changes:
#       npm run gen:types
# 6) Supabase Auth → URL Configuration: add redirect URL(s), e.g.
#       http://localhost:3000/auth/callback
#       https://<your-production-domain>/auth/callback
#       (add preview URLs for Vercel preview deployments if you use OAuth / magic links)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: add in Vercel for Production + Preview (+ Development if needed). Not always injected by the Supabase integration.
SUPABASE_SERVICE_ROLE_KEY=

# Optional integration tests
TEST_SUPABASE_URL=
TEST_SUPABASE_ANON_KEY=

# Edge Function (Resend)
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=Training Hub <onboarding@resend.dev>
