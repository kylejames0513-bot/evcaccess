# --- Supabase + Vercel (Training Hub) ---
# 1) Vercel: link this repo to your project (creates .vercel/project.json; not committed):
#       npm run vercel:link
# 2) Supabase: either
#    A) Vercel Marketplace — Project → Storage → Supabase (or): npx vercel integration add supabase
#       then sync env to your machine: npm run vercel:env:pull
#    B) Existing project — copy Project URL + anon + service_role from Supabase Dashboard →
#       Settings → API into Vercel Environment Variables, then npm run vercel:env:pull
# 3) Link Supabase CLI to the same project (writes .supabase locally; not committed):
#       npm run supabase:link
# 4) Apply DB schema (public tables, RLS):
#       npm run db:push
# 5) Create the shared HR auth user (Supabase Auth Admin API):
#       npm run db:ensure-hr-user
#    Or: npm run db:setup  (= db:push && db:ensure-hr-user)
# 6) Regenerate TS types after schema changes:
#       npm run gen:types
# 7) Supabase Auth → URL Configuration: add redirect URL(s), e.g.
#       http://localhost:3000/auth/callback
#       https://<your-production-domain>/auth/callback
#       (add preview URLs for Vercel preview deployments if you use OAuth / magic links)

# If you see "Invalid API key" on login: URL + anon key must be from the SAME Supabase project.
# Use the Dashboard → Connect → App frameworks → Next.js, or copy anon (not service_role).
# Vercel integration often sets SUPABASE_URL + SUPABASE_ANON_KEY only — next.config maps those for the client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional fallbacks (same project as above; preferred for Vercel integration + server-side login):
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_PUBLISHABLE_KEY=
# Server-only: add in Vercel for Production + Preview (+ Development if needed). Not always injected by the Supabase integration.
SUPABASE_SERVICE_ROLE_KEY=

# Optional — HR gate (defaults match src/lib/auth/general-hr.ts and scripts/ensure-general-hr-user.cjs):
# GENERAL_HR_AUTH_EMAIL=general-hr@training-hub.local
# GENERAL_HR_PASSWORD=tennyson

# Optional integration tests
TEST_SUPABASE_URL=
TEST_SUPABASE_ANON_KEY=

# Edge Function (Resend)
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=Training Hub <onboarding@resend.dev>

# --- HR Hub Ingestion ---
# Source A: Merged Employee Master (Google Sheet published CSV)
MERGED_MASTER_CSV_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vRfYncvxqS6nzzmCK9R_WsGWdj8QLVe1qF0VEF4emO_1aDyFnOVjSSi9ndHy8G_Qq3ZYq17WmCH9-Ng/pub?gid=1209127026&single=true&output=csv

# Source B: Attendance Tracker Training tab (Google Sheet published CSV)
ATTENDANCE_TRACKER_CSV_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vSrqHNYlebocrv8AARfLon065YuST3Yo_PSwH5WGoBK6B4bjlBKGNGlX82ccLq5kZqkZ5Devknz2oho/pub?gid=313450341&single=true&output=csv

# Vercel cron auth
CRON_SECRET=

# Google Apps Script web app URL (for dual-write to Training Records sheet)
# Deploy your Apps Script as a web app and paste the URL here.
#
# The public kiosk (/signin/[org_slug]) posts training sign-ins to this URL.
# If unset, it falls back to the embedded hard-coded URL in
# src/components/training-hub/kiosk-sign-in-form.tsx — keep this env var set
# in production so you can rotate the Apps Script without redeploying code.
GOOGLE_APPS_SCRIPT_URL=
# Client-readable mirror used by the kiosk (must start with NEXT_PUBLIC_):
NEXT_PUBLIC_GOOGLE_APPS_SCRIPT_URL=
